  "fields": {
    "issuetype": {"name": "Story"},
    "project": {"key": "BBIT", "name": "Bright Bits"},
    "summary": "Add header CTA button for activation flow",
    "status": {"name": "Done"},
    "assignee": {"accountId": "dulce-id", "displayName": "Dulce Hernandez Cruz"},
    "reporter": {"accountId": "yanna-id", "displayName": "Yanna Lopes"},
    "created": "2026-03-08T09:00:00.000+0000",
    "resolutiondate": "2026-03-22T16:00:00.000+0000",
    "parent": {"key": "BBIT-100", "fields": {"issuetype": {"name": "Epic"}}},
    "description": {
      "version": 1,
      "type": "doc",
      "content": [
        {
          "type": "heading",
          "attrs": {"level": 2},
          "content": [{"type": "text", "text": "Business Objective"}]
        },
        {
          "type": "paragraph",
          "content": [{"type": "text", "text": "Drive activation rate by 10% within Q2 by surfacing the upgrade CTA earlier in the user journey."}]
        },
        {
          "type": "heading",
          "attrs": {"level": 2},
          "content": [{"type": "text", "text": "Observable Impact"}]
        },
        {
          "type": "paragraph",
          "content": [{"type": "text", "text": "Activation rate (first meaningful action within 7 days of signup) increases by 10%. Measured in Amplitude dashboard \u2018Onboarding Funnel\u2019 within 30 days of shipping."}]
        },
        {
          "type": "heading",
          "attrs": {"level": 2},
          "content": [{"type": "text", "text": "Acceptance Criteria"}]
        },
        {
          "type": "paragraph",
          "content": [{"type": "text", "text": "- CTA button appears in header for users who have not completed activation\n- Button label reads \u201cGet started\u201d\n- Clicking button navigates to /onboarding\n- Button is hidden for users with activation_completed = true\n- Accessible: keyboard-focusable, meets AA contrast"}]
        },
        {
          "type": "heading",
          "attrs": {"level": 2},
          "content": [{"type": "text", "text": "Scenarios"}]
        },
        {
          "type": "paragraph",
          "content": [{"type": "text", "text": "Given a logged-in user without activation_completed\nWhen they view any authenticated page\nThen the CTA button appears in the header\n\nGiven a logged-in user with activation_completed = true\nWhen they view any authenticated page\nThen no CTA button is visible in the header"}]
        },
        {
          "type": "heading",
          "attrs": {"level": 2},
          "content": [{"type": "text", "text": "Risks"}]
        },
        {
          "type": "paragraph",
          "content": [{"type": "text", "text": "Feature flag dependency: if flag service is unavailable, button defaults to hidden (safe fail). Confirm with ops before deploy."}]
        }
      ]
    },
    "subtasks": [
      {"key": "BBIT-496", "fields": {"summary": "Implement header CTA button", "issuetype": {"name": "Sub-task"}}},
      {"key": "BBIT-497", "fields": {"summary": "Tests \u2014 BBIT-495", "issuetype": {"name": "Sub-task"}}}
    ],
