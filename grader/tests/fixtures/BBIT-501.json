        }
      }
    },
    "description": {
      "version": 1,
      "type": "doc",
      "content": [
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Business Objective"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Reduce unauthorized access by requiring 2FA for all admin accounts before end of Q1."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Observable Impact"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Zero admin accounts without 2FA within 30 days of shipping. Measured in the Security Dashboard under Admin Accounts."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "- All admin users are prompted to enroll in 2FA on next login\n- Users cannot access admin panel without completing 2FA setup\n- Recovery codes are generated and shown once at enrollment\n- Admins can disable 2FA only with super-admin approval"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Scenarios"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Given an admin user without 2FA enrolled\nWhen they log in\nThen they are redirected to 2FA setup before accessing the admin panel\n\nGiven an admin user with 2FA enrolled\nWhen they log in\nThen they pass 2FA challenge and reach the admin panel normally"
            }
          ]
        }
      ]
    },
